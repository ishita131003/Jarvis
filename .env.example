# ==========================================
# J.A.R.V.I.S. Environment Configuration
# ==========================================

# 1. Supabase Authentication (Required for Login)
# Get these by creating a free project at https://supabase.com/
# Then go to Project Settings -> API
SUPABASE_URL="your-supabase-project-url-here"
SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# 2. AI Engine API Keys (Required for Intelligence)
OPENROUTER_API_KEY="your-openrouter-key-here" 
HF_API_KEY="your-huggingface-key-here"

# 3. Server Configuration (Optional)
# Set to 'true' if running on Render.com
RENDER="false" 
PORT=5000
